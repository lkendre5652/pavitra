rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.email is string &&
             data.email.size() <= 100 &&
             data.role in ['user', 'admin', 'superadmin'];
    }

    function isValidProfile(data) {
      return data.userId is string &&
             data.fullName is string &&
             data.fullName.size() <= 100 &&
             data.age is int &&
             data.age >= 18 &&
             data.age <= 100;
             // Add more validations as needed
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().role == existing().role; // Prevent self-elevation
    }

    match /profiles/{profileId} {
      allow read: if isSignedIn(); // Logged in users can view approved profiles
      allow create: if isSignedIn() && 
                    isValidProfile(incoming()) && 
                    incoming().userId == request.auth.uid;
      allow update: if (isOwner(existing().userId) && 
                      isValidProfile(incoming()) && 
                      incoming().userId == existing().userId &&
                      incoming().isApproved == existing().isApproved) // User can't self-approve
                    || isAdmin();
    }

    match /interests/{interestId} {
      allow read: if isSignedIn() && (
        resource.data.fromUserId == request.auth.uid || 
        resource.data.toUserId == request.auth.uid
      );
      allow create: if isSignedIn() && 
                    incoming().fromUserId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.toUserId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
    }

    match /membership_plans/{planId} {
      allow read: if true; // Publicly readable
    }
  }
}
